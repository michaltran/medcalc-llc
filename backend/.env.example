# ===== Server =====
PORT=4000
NODE_ENV=development

# ===== JWT =====
# Tạo secret: openssl rand -hex 32
JWT_SECRET=ttyt-lien-chieu-CHANGE-ME-IN-PRODUCTION

# ===== PostgreSQL =====
# Cách 1: Connection string (khuyến nghị, dễ dùng cho Vercel)
DATABASE_URL=postgresql://medcalc_user:your_password@localhost:5432/medcalc_db

# Cách 2: Các tham số rời (nếu không dùng DATABASE_URL)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=medcalc_db
# PGUSER=medcalc_user
# PGPASSWORD=your_password

# Bật SSL khi kết nối qua mạng public (Vercel → DB server vật lý)
PGSSL=false
