# ===== Bắt buộc đặt trên Vercel Dashboard (Project → Settings → Environment Variables) =====

# JWT Secret - tạo bằng: openssl rand -hex 32
JWT_SECRET=

# PostgreSQL connection
# Nếu DB nội bộ TTYT có public IP/domain:
DATABASE_URL=postgresql://medcalc_user:password@your-server.example.com:5432/medcalc_db

# Bắt buộc bật SSL khi kết nối qua Internet (Vercel → DB)
PGSSL=true

# ===== Khuyến nghị =====
# Nếu PostgreSQL chỉ accept SSL với cert tự ký, vẫn để PGSSL=true
# (driver pg đã được config rejectUnauthorized:false trong _lib/db.js)
